    "extension_rules": [
      "Prefer new node_type values before new top-level sections.",
      "Prefer controlled vocabulary expansion before structural redesign.",
      "Prefer optional field groups before changing the recursive skeleton.",
      "Prefer relationships and subnodes before duplicating data.",
      "Only add a new top-level field family if the new thing cannot fit any existing category without distortion.",
      "Prefer inheritance and stricter control defaults before local overrides.",
      "Prefer adding dormant optional fields over redesigning the recursive shell.",
      "Never allow blank values to imply destructive permission."
    ],

+++ b/tools/build_priority_report.py
@@ -0,0 +1,120 @@
+"""Build a priority report from the stitched example dataset."""
+
+from __future__ import annotations
+
+import json
+from pathlib import Path
+
+
+ROOT = Path(__file__).resolve().parents[1]
+EXAMPLES = ROOT / "examples"
+BUILD = ROOT / "build"
+
+
+def load_json(path: Path) -> dict:
+    with path.open("r", encoding="utf-8") as handle:
+        return json.load(handle)
+
+
+def main() -> None:
+    BUILD.mkdir(parents=True, exist_ok=True)
+
+    exception = load_json(EXAMPLES / "exception-event.sample.json")
+    pressure = load_json(EXAMPLES / "pressure-vector.sample.json")
+    resolution = load_json(EXAMPLES / "resolution-action.sample.json")
+    promotion = load_json(EXAMPLES / "promotion-log.sample.json")
+
+    pressure_total = sum(
+        pressure[lens]
+        for lens in [
+            "theological",
+            "psychological",
+            "moral",
+            "political",
+            "economic",
+            "cultural",
+        ]
+    )
+
+    priority_score = round(
+        (exception["fix_score"] * 0.55)
+        + (exception["learn_score"] * 0.45)
+        + pressure_total,
+        2,
+    )
+
+    queue = [
+        {
+            "exception_id": exception["exception_id"],
+            "address_id": exception["address_id"],
+            "exception_type": exception["exception_type"],
+            "disposition_class": exception["disposition_class"],
+            "fix_score": exception["fix_score"],
+            "learn_score": exception["learn_score"],
+            "pressure_intensity": pressure_total,
+            "priority_score": priority_score,
+            "dominant_pressures": pressure["dominant_pressures"],
+            "status": exception["status"],
+            "promotion_target": promotion["promoted_to_scope"],
+            "decision_record_id": exception["decision_record_id"],
+        }
+    ]
+
+    (BUILD / "priority_queue.json").write_text(
+        json.dumps(queue, indent=2),
+        encoding="utf-8",
+    )
+
+    report = f"""# Exceptions priority report
+
+- Exceptions: **1**
+- Resolutions: **1**
+- Promotions: **1**
+
+## Priority queue
+
+| Exception | Type | Fix | Learn | Pressure | Priority | Promotion |
+|---|---:|---:|---:|---:|---:|---|
+| {exception['exception_id']} | {exception['exception_type']} | {exception['fix_score']} | {exception['learn_score']} | {pressure_total} | {priority_score} | {promotion['promoted_to_scope']} |
+
+## Pressure totals
+
+| Lens | Total |
+|---|---:|
+| theological | {pressure['theological']} |
+| psychological | {pressure['psychological']} |
+| moral | {pressure['moral']} |
+| political | {pressure['political']} |
+| economic | {pressure['economic']} |
+| cultural | {pressure['cultural']} |
+
+## Recommended immediate focus
+
+Top issue: `{exception['exception_id']}` at address `{load_json(EXAMPLES / 'address-node.sample.json')['address']}`
+"""
+
+    (BUILD / "priority_report.md").write_text(report, encoding="utf-8")
+
+    print("Wrote build/priority_queue.json and build/priority_report.md")
+
+
+if __name__ == "__main__":
+    main()
diff --git a/tools/validate_examples.py b/tools/validate_examples.py
new file mode 100644

+++ b/tools/validate_examples.py
@@ -0,0 +1,114 @@
+"""Validate example records against the schema contracts."""
+
+from __future__ import annotations
+
+import json
+from pathlib import Path
+
+from jsonschema import Draft202012Validator
+from referencing import Registry, Resource
+
+
+ROOT = Path(__file__).resolve().parents[1]
+SCHEMA_DIR = ROOT / "schema"
+EXAMPLES_DIR = ROOT / "examples"
+
+
+SCHEMA_FILES = {
+    "common.schema.json": "common.schema.json",
+    "address-node.schema.json": "address-node.schema.json",
+    "expectation.schema.json": "expectation.schema.json",
+    "observation-event.schema.json": "observation-event.schema.json",
+    "evidence-ref.schema.json": "evidence-ref.schema.json",
+    "exception-event.schema.json": "exception-event.schema.json",
+    "pressure-vector.schema.json": "pressure-vector.schema.json",
+    "resolution-action.schema.json": "resolution-action.schema.json",
+    "promotion-log.schema.json": "promotion-log.schema.json",
+    "decision-record.schema.json": "decision-record.schema.json",
+    "dataset.schema.json": "dataset.schema.json",
+}
+
+
+def load_json(path: Path) -> dict:
+    with path.open("r", encoding="utf-8") as handle:
+        return json.load(handle)
+
+
+def build_registry() -> Registry:
+    resources = {}
+    for filename, uri in SCHEMA_FILES.items():
+        schema = load_json(SCHEMA_DIR / filename)
+        resources[uri] = Resource.from_contents(schema)
+    return Registry().with_resources(resources.items())
+
+
+def validate_example(schema_name: str, example_name: str, registry: Registry) -> None:
+    schema = load_json(SCHEMA_DIR / schema_name)
+    example = load_json(EXAMPLES_DIR / example_name)
+    validator = Draft202012Validator(schema, registry=registry)
+    errors = sorted(validator.iter_errors(example), key=lambda item: item.path)
+    if errors:
+        joined = "\n".join(
+            f"- {'/'.join(map(str, err.path)) or '<root>'}: {err.message}"
+            for err in errors
+        )
+        raise ValueError(f"{example_name} failed validation:\n{joined}")
+
+
+def validate_cross_refs() -> None:
+    exception = load_json(EXAMPLES_DIR / "exception-event.sample.json")
+    observation = load_json(EXAMPLES_DIR / "observation-event.sample.json")
+    pressure = load_json(EXAMPLES_DIR / "pressure-vector.sample.json")
+    resolution = load_json(EXAMPLES_DIR / "resolution-action.sample.json")
+    promotion = load_json(EXAMPLES_DIR / "promotion-log.sample.json")
+    decision = load_json(EXAMPLES_DIR / "decision-record.sample.json")
+
+    assert observation["observation_id"] == exception["observation_id"]
+    assert pressure["exception_id"] == exception["exception_id"]
+    assert resolution["exception_id"] == exception["exception_id"]
+    assert promotion["source_exception_id"] == exception["exception_id"]
+    assert decision["decision_id"] == exception["decision_record_id"]
+
+    fix_score = (
+        exception["recurrence_count"]
+        * exception["severity"]
+        * exception["blast_radius"]
+        * exception["unresolved_age_days"]
+    )
+    if fix_score != exception["fix_score"]:
+        raise ValueError(
+            f"fix_score mismatch: expected {fix_score}, found {exception['fix_score']}"
+        )
+
+    learn_score = (
+        exception["recurrence_count"]
+        * exception["novelty_score"]
+        * exception["cross_domain_spread"]
+        * exception["failed_resolution_rate"]
+    )
+    if learn_score != exception["learn_score"]:
+        raise ValueError(
+            f"learn_score mismatch: expected {learn_score}, found {exception['learn_score']}"
+        )
+
+
+def main() -> None:
+    registry = build_registry()
+    validate_example("address-node.schema.json", "address-node.sample.json", registry)
+    validate_example("expectation.schema.json", "expectation.sample.json", registry)
+    validate_example("observation-event.schema.json", "observation-event.sample.json", registry)
+    validate_example("evidence-ref.schema.json", "evidence-ref-1.sample.json", registry)
+    validate_example("evidence-ref.schema.json", "evidence-ref-2.sample.json", registry)
+    validate_example("exception-event.schema.json", "exception-event.sample.json", registry)
+    validate_example("pressure-vector.schema.json", "pressure-vector.sample.json", registry)
+    validate_example("resolution-action.schema.json", "resolution-action.sample.json", registry)
+    validate_example("promotion-log.schema.json", "promotion-log.sample.json", registry)
+    validate_example("decision-record.schema.json", "decision-record.sample.json", registry)
+    validate_example("dataset.schema.json", "full-example.dataset.json", registry)
+    validate_cross_refs()
+    print("All examples validated successfully.")
+
+
+if __name__ == "__main__":
+    main()

